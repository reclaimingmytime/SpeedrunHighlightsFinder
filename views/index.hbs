<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⛏️</text></svg>">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sakura.css@1.5.1/css/sakura.css"
          integrity="sha256-rFoyAIn+rtUKyWRsd6hDbzlnJmklIRroszMxG/mjxeY=" crossorigin="anonymous">
    <style>
        a:visited {
            color: #982c61;
        }

        p {
            margin-bottom: 16px;
        }

        /* nav link states */
        a.nav-inactive {
            color: #999;
            pointer-events: none;
            text-decoration: none;
            cursor: default;
        }
    </style>
    <title>{{#if user}}{{user}} - {{/if}}MCSR Ranked Highlights</title>
</head>
<body>
<h1>MCSR Ranked Highlights</h1>

<div style="margin-bottom: 0.75rem;">
    <a href="/" class="{{#if isLatest}}nav-inactive{{/if}}">
        Highlights
    </a>
    |
    <a href="/?view=latestFromHistory" class="{{#if isLatestFromHistory}}nav-inactive{{/if}}">
        Latest from History
    </a>
    |
    <a href="/?view=history" class="{{#if isHistory}}nav-inactive{{/if}}">
        History
    </a>
</div>

{{#if isLatest}}
    <form id="searchForm">
        <label for="user" style="display: inline">Player:</label>
        <input type="search" id="user" name="user" placeholder="All players" value="{{user}}">
        <label for="season" style="display: inline">Season:</label>
        <input type="number" id="season" name="season" min="8" placeholder="current" value="{{season}}"
               style="display: inline-block; width: 79px">
        <button type="submit">Submit</button>
    </form>
{{/if}}


{{#if isLatestFromHistory}}
    <div id="latestFromHistoryStatus">
        Loading latest matches...
    </div>
{{/if}}

<div id="latestMatchesContainer">
    {{#if error}}
        <p id="error" style="color: red;">{{error}}</p>
    {{else}}
        {{#if isLatest}}
            {{#each vods}}
                <p>
                    <a href="?user={{vodNickname}}" title="See all highlights by player">
                    <img src="https://mineskin.eu/avatar/{{vodNickname}}/8.svg"
                         style="height: 18px; display: inline; margin-bottom: 0;" alt="Player Avatar">
                    </a>
                    <a href="{{vodLink}}" rel="noreferrer" target="_blank">{{vodNickname}} at {{vodTime}}</a>
                </p>
            {{else}}
                <p>No highlights found.</p>
            {{/each}}

            {{#if lastMatchId}}
                <hr>
                <p>
                <a href="?{{#if user}}user={{user}}&amp;{{/if}}before={{lastMatchId}}{{#if season}}&amp;season={{season}}{{/if}}">Previous</a>
                    {{#if user}}{{#unless error}}|
                        <a href="#" id="toggleOpponentClips" data-value="{{#if includeOpponent}}false{{else}}true{{/if}}">
                            {{#if includeOpponent}}Hide opponent clips{{else}}Include opponent{{/if}}
                        </a>
                    {{/unless}}{{/if}}
                </p>
            {{/if}}
        {{/if}}
    {{/if}}
</div>


{{#if isHistory}}
    <div id="searchHistoryPanel" style="margin-top: 1rem;">
        <p id="historyInfoMessage" style="display:none;"></p>

        <div id="historyContainer"></div>

        <button id="clearHistory" type="button" style="display: none;">Clear history</button>
    </div>

{{/if}}

<script src="/js/script.js"></script>
</body>
</html>